{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "photoURL": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "gender": { "type": "string", "enum": ["male", "female", "other"] },
        "status": { "type": "string" },
        "lastSeen": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "Chat": {
      "title": "Chat",
      "description": "A conversation between users",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "participants": { "type": "array", "items": { "type": "string" } },
        "participantDetails": { "type": "object" },
        "lastMessage": { "type": "object" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "isAI": { "type": "boolean" },
        "aiConfig": { "type": "object" },
        "typing": { "type": "object" }
      },
      "required": ["participants", "updatedAt"]
    },
    "Message": {
      "title": "Message",
      "description": "An individual message in a chat",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "chatId": { "type": "string" },
        "senderId": { "type": "string" },
        "text": { "type": "string" },
        "type": { "enum": ["text", "image", "video", "audio"] },
        "mediaUrl": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "replyTo": { "type": "object" }
      },
      "required": ["chatId", "senderId", "timestamp", "type"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "chats/{chatId}": {
      "schema": "Chat",
      "description": "Conversations"
    },
    "chats/{chatId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Messages within a chat"
    }
  }
}
